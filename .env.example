# ─────────────────────────────────────────────────────────────
# Agency Platform — Environment Variables
# Copy this to .env.local and fill in your keys
# ─────────────────────────────────────────────────────────────

# Claude API (Required for website generation)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps Places API (Required for business discovery)
# Get from: https://console.cloud.google.com/ → APIs → Places API
GOOGLE_MAPS_API_KEY=AIza...

# Vercel API Token (Optional — needed only for one-click deploy)
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=...
