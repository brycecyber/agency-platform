# Copy this file to .env.local and fill in your keys

# Anthropic (Claude API) — get at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Maps Places API — get at https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Vercel API — get at https://vercel.com/account/tokens
VERCEL_API_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=                # optional, leave blank if personal account

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
